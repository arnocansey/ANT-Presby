# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=antpress
DB_USER=postgres
DB_PASSWORD=your_password_here
# Optional: preferred by Prisma
DATABASE_URL=postgresql://postgres:your_password_here@localhost:5432/antpress?schema=public

# Server Configuration
NODE_ENV=development
PORT=5000
LOG_LEVEL=debug

# JWT Configuration
JWT_SECRET=ki11g0recre@tem3
JWT_EXPIRATION=1d
JWT_REFRESH_SECRET=wH01suP3rS3cr3tR3fr3shK3yCh4ng3InPr0ducti0n
REFRESH_TOKEN_EXPIRATION=30d
ACCESS_TOKEN_COOKIE_NAME=access_token
REFRESH_TOKEN_COOKIE_NAME=refresh_token

# CORS Configuration
FRONTEND_URL=http://localhost:3000
APP_BASE_URL=http://localhost:3000
# Optional comma-separated allowlist for additional web origins, previews, or staging
CORS_ORIGINS=

# Email Configuration (Optional - for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=ANT PRESS <no-reply@yourdomain.com>

# Payment Gateway (Optional - Paystack)
PAYSTACK_PUBLIC_KEY=your_paystack_public_key
PAYSTACK_SECRET_KEY=your_paystack_secret_key

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads
PRISMA_CONNECTION_LIMIT=15
PRISMA_POOL_TIMEOUT=30

# Optional bootstrap admin for npm run seed
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_FIRST_NAME=
SEED_ADMIN_LAST_NAME=
SEED_ADMIN_PHONE=

# API Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

